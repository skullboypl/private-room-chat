# Public URL of your deployment (required for SEO, invites, and metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# HTTP server
PORT=3000
HOST=0.0.0.0
QUIET_LOGS=0

# Optional comma-separated Socket.IO CORS origins (defaults include localhost + SITE_URL)
# CORS_ORIGINS=http://localhost:3000,https://chat.example.com

# Optional branding
# SITE_NAME=Pokoje Czatu
# SITE_TAGLINE=Prywatne pokoje czatu online z szyfrowaniem E2E

# Optional E2E salt prefix (changing breaks decryption of existing rooms)
# NEXT_PUBLIC_E2E_SALT_PREFIX=pokoje-czatu-e2e-v2

# Optional secret for encrypting localStorage/sessionStorage (set in production)
# NEXT_PUBLIC_VXH_STORAGE_SECRET=change-me-to-a-long-random-string
